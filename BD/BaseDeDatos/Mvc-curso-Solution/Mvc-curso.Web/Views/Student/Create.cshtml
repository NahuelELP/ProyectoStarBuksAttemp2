@model Mvc_curso.Domain.Entities.Student;
<h1>Form Create</h1>

<from asp-action="Store" asp-controller="Student">
	@* //Crear metodo store *@
	<div>
		<input asp-for="FullName" type="type" placeholder="FullName" />
	</div>
	<div>
		<input asp-for="Age" type="type" placeholder="Age" />
	</div>
	<div>
		<input asp-for="Country" type="type" placeholder="Country" />
	</div>
	<div class="d-grid gap-2">
		<button type="submit" class="btn btn-primary">Save</button>
		<a asp-controller="Student" asp-action="Index" class="btn btn-secondary">Cancel</a>
	</div>
</from>